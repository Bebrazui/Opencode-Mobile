<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0D1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="#FFFFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="24dp" />

        <!-- Server Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_server"
            android:textColor="#FF58A6FF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF161B22"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/server_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF7EE787"
                android:textSize="14sp"
                android:text="Checking..." />

            <TextView
                android:id="@+id/restart_btn"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="@string/settings_server_restart"
                android:textColor="#FF58A6FF"
                android:textSize="13sp"
                android:background="@drawable/btn_border"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Data Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_data"
            android:textColor="#FF58A6FF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF161B22"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/db_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF8B949E"
                android:textSize="14sp"
                android:text="Database: ..." />

            <TextView
                android:id="@+id/export_btn"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="@string/settings_export"
                android:textColor="#FF58A6FF"
                android:textSize="13sp"
                android:background="@drawable/btn_border"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/import_btn"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="@string/settings_import"
                android:textColor="#FF58A6FF"
                android:textSize="13sp"
                android:background="@drawable/btn_border"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/import_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF8B949E"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- About Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_about"
            android:textColor="#FF58A6FF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF161B22"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/about_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF8B949E"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/about_db_path"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF8B949E"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/about_storage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF8B949E"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
